<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /

	# Canonical host: 301 redirect non-www -> www (matches canonical tags, one true address)
	RewriteCond %{HTTP_HOST} ^brandkraf\.com$ [NC]
	RewriteRule ^(.*)$ https://www.brandkraf.com/$1 [R=301,L]

	# SPA fallback: serve index.html for anything that isn't a real file or directory
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
	Header set X-Powered-By "Hostinger Horizons"

	# HTML / app routes: never edge-cache, always revalidate so new deploys appear instantly
	Header set Cache-Control "public, s-maxage=0, max-age=0, must-revalidate"

	# Hashed build assets are content-addressed (filenames change per build) — cache hard
	<If "%{REQUEST_URI} =~ m#^/assets/.*$#">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</If>
</IfModule>
